def point_in_rect(px, py, rx, ry, rw, rh)
{
    if (px < rx) return false;
    if (py < ry) return false;
    if (px > rx + rw) return false;
    if (py > ry + rh) return false;
    return true;
}

def update_pointer()
{
    var touch_down = (touch_count() > 0);
    if (touch_down)
    {
        POINTER_X = get_touch_screen_x(0);
        POINTER_Y = get_touch_screen_y(0);
    }
    else
    {
        POINTER_X = get_mouse_x();
        POINTER_Y = get_mouse_y();
    }

    POINTER_DOWN = (touch_down || mouse_down(0));
    POINTER_PRESSED = (POINTER_DOWN && !POINTER_WAS_DOWN);
    POINTER_WAS_DOWN = POINTER_DOWN;
}

def load_graph_safe(_path)
{
    var gid = load_graph(_path);
    if (!gid) return -1;
    if (gid < 0) return -1;
    return gid;
}

def load_sound_safe(_path)
{
    if (SFX_PLACEHOLDER_MODE) return -1;
    var sid = load_sound(_path);
    if (!sid) return -1;
    if (sid < 0) return -1;
    return sid;
}

def load_music_safe(_path)
{
    if (SFX_PLACEHOLDER_MODE) return -1;
    var mid = load_music(_path);
    if (mid < 0) return -1;
    return mid;
}

def load_graph_asset(_rel)
{
    var gid = load_graph_safe("assets/" + _rel);
    if (gid >= 0) return gid;
    gid = load_graph_safe(_rel);
    if (gid >= 0) return gid;
    ASSETS_FAILED += 1;
    return -1;
}

def load_sound_asset(_rel)
{
    var sid = load_sound_safe("assets/" + _rel);
    if (sid >= 0) return sid;
    return load_sound_safe(_rel);
}

def load_music_asset(_rel)
{
    var mid = load_music_safe("assets/" + _rel);
    if (mid >= 0) return mid;
    return load_music_safe(_rel);
}

def play_sound_safe(_sid, _vol, _pitch)
{
    if (_sid < 0) return;
    var final_vol = _vol * SOUND_VOLUME;
    if (final_vol <= 0.0) return;
    play_sound(_sid, final_vol, _pitch);
}

def get_music_volume()
{
    return SOUND_VOLUME * MUSIC_VOLUME_BASE;
}

def apply_music_volume_all()
{
    var mv = get_music_volume();
    if (MUS_MENU >= 0) set_music_volume(MUS_MENU, mv);
    if (MUS_CREDITS >= 0 && MUS_CREDITS != MUS_MENU) set_music_volume(MUS_CREDITS, mv);
    if (MUS_GAME >= 0 && MUS_GAME != MUS_MENU && MUS_GAME != MUS_CREDITS) set_music_volume(MUS_GAME, mv);
}

def target_music_for_state()
{
    if (GAME_STATE == STATE_MENU) return MUS_MENU;
    if (GAME_STATE == STATE_CREDITS) return MUS_CREDITS;
    return MUS_GAME;
}

def update_music_state()
{
    update_music_streams();

    var target = target_music_for_state();
    if (target < 0)
    {
        MUS_CURRENT = -1;
        return;
    }

    var mv = get_music_volume();
    if (MUS_CURRENT != target)
    {
        if (MUS_CURRENT >= 0 && MUS_CURRENT != target) stop_music(MUS_CURRENT);
        set_music_volume(target, mv);
        play_music(target);
        MUS_CURRENT = target;
        return;
    }

    set_music_volume(target, mv);
    if (!is_music_playing(target)) play_music(target);
}

def sound_button_hit(px, py)
{
    return point_in_rect(px, py, SOUND_BTN_X, SOUND_BTN_Y, SOUND_BTN_W, SOUND_BTN_H);
}

def update_sound_toggle()
{
    if (!POINTER_PRESSED) return;
    if (!sound_button_hit(POINTER_X, POINTER_Y)) return;

    if (SOUND_MUTED)
    {
        SOUND_MUTED = false;
        SOUND_VOLUME = SOUND_VOLUME_NORMAL;
        play_sound_safe(SND_UI_OK, 0.9, 1.0);
    }
    else
    {
        SOUND_MUTED = true;
        SOUND_VOLUME = 0.0;
    }

    apply_music_volume_all();

    // Consome o clique para nao ativar outros botoes no mesmo frame.
    POINTER_PRESSED = false;
}

def draw_sound_toggle_button()
{
    set_draw_screen(true);

    var hot = sound_button_hit(POINTER_X, POINTER_Y);
    if (SOUND_MUTED)
    {
        if (hot) set_color(126, 76, 76);
        else set_color(96, 58, 58);
    }
    else
    {
        if (hot) set_color(84, 122, 90);
        else set_color(62, 94, 68);
    }
    draw_rectangle(SOUND_BTN_X, SOUND_BTN_Y, SOUND_BTN_W, SOUND_BTN_H, true);

    if (SOUND_MUTED) set_color(240, 182, 182);
    else set_color(192, 240, 204);
    draw_rectangle(SOUND_BTN_X, SOUND_BTN_Y, SOUND_BTN_W, SOUND_BTN_H, false);

    if (SOUND_MUTED)
    {
        set_color(12, 8, 8);
        draw_text("MUTE", SOUND_BTN_X + 15, SOUND_BTN_Y + 7, 18);
        set_color(255, 232, 232);
        draw_text("MUTE", SOUND_BTN_X + 14, SOUND_BTN_Y + 6, 18);
    }
    else
    {
        set_color(8, 12, 8);
        draw_text("SND ON", SOUND_BTN_X + 9, SOUND_BTN_Y + 7, 18);
        set_color(232, 255, 236);
        draw_text("SND ON", SOUND_BTN_X + 8, SOUND_BTN_Y + 6, 18);
    }
    set_draw_screen(false);
}

def count_valid(_arr)
{
    var i = 0;
    var c = 0;
    while (i < len(_arr))
    {
        if (_arr[i] >= 0) c += 1;
        i += 1;
    }
    return c;
}

def draw_graph_or_card(_graph, _x, _y, _w, _h, _label)
{
    if (_graph >= 0)
    {
        draw_graph(_graph, _x, _y);
        return;
    }
    set_color(42, 52, 70);
    draw_rectangle(_x, _y, _w, _h, true);
    set_color(120, 145, 175);
    draw_rectangle(_x, _y, _w, _h, false);
    set_color(220, 230, 245);
    draw_text(_label, _x + 16, _y + 20, 24);
}

